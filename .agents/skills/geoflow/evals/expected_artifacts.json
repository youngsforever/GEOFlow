  "mode_outputs": {
    "development": ["changed-files", "contract-impact", "verification-result"],
    "operations": ["surface-used", "resource-readback", "final-state"],
    "public_frontend": ["target-theme-or-payload", "preview-evidence", "contract-check"],
    "channel_frontend": ["capability-status", "sync-preview", "rollback-note"],
    "legacy_migration": ["legacy-inventory", "laravel-mapping", "migration-handoff"]
  },
  "required_report_fields": [
    "selected-mode",
    "source-of-truth",
    "targets-touched",
    "verification",
    "final-state",
    "remaining-risks"
  ],
  "quality_expectations": {
    "development": [
      "discover current code and route contracts before editing",
      "include focused tests for changed backend, admin, API, CLI, queue, or frontend behavior"
    ],
    "operations": [
      "use a supported CLI, API v1, or authenticated admin surface",
      "run preflight before mutation and read back persisted state"
    ],
    "public_frontend": [
      "preserve Laravel theme, route, SEO, article-data, and lead-form contracts",
      "use preview-first theme staging and require confirmation for live replacement"
    ],
    "channel_frontend": [
      "compare default, packaged, cached, and live target capabilities before sync",
      "surface unsupported modules, confirmation requirements, and rollback guidance"
    ],
    "legacy_migration": [
      "inventory old PHP entrypoints and data contracts before mapping",
      "store replacement backups outside a legacy web root and verify the Laravel target"
    ],
    "package": [
      "retain every required file across source, archive, and installed skill roots",
      "exclude caches, local logs, screenshots, credentials, and temporary outputs"
    ]
  },
  "forbidden_behaviors": [
    "invented-routes-or-cli-commands",
    "direct-production-sql-shortcuts",
    "authentication-or-csrf-bypass",
    "secret-or-personal-data-exposure",
    "unreviewed-live-theme-or-channel-publication",
    "unsupported-remote-module-sync"
  ]
}
